# Anthropic API Key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
# Set authorized redirect URI to: https://your-domain.com/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET=

# Your deployment URL (no trailing slash)
# Local: http://localhost:3000
# Production: https://your-vercel-url.vercel.app
NEXTAUTH_URL=http://localhost:3000

# OpenAI API Key — optional, enables Whisper transcription fallback
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Optional: override root folder name in Google Drive (default: KnowledgeBase)
KB_ROOT_FOLDER=KnowledgeBase
